{
  "name": "verbyprompt",
  "version": "0.1.0",
  "description": "Voice-to-prompt desktop app",
  "author": "Stephen Grandy",
  "main": "src/main/index.js",
  "scripts": {
    "start": "concurrently --kill-others \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build:renderer": "vite build",
    "build:app": "electron-builder --mac",
    "build": "npm run build:renderer && npm run build:app",
    "release": "npm run build:renderer && electron-builder --mac --publish never",
    "postinstall": "electron-builder install-app-deps"
  },
  "license": "MIT",
  "build": {
    "appId": "com.verby.prompt",
    "productName": "VerbyPrompt",
    "icon": "assets/icon.icns",
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "identity": "Stephen Grandy (3AK8389YMS)",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "electronLanguages": ["en"],
      "extendInfo": {
        "NSMicrophoneUsageDescription": "VerbyPrompt needs microphone access to transcribe your speech.",
        "NSAccessibilityUsageDescription": "VerbyPrompt needs Accessibility access to inject text into other apps."
      },
      "extraResources": [
        {
          "from": "native/fn-capture",
          "to": "native/fn-capture"
        },
        {
          "from": "native/text-inject",
          "to": "native/text-inject"
        }
      ]
    },
    "dmg": {
      "background": null,
      "icon": "assets/icon.icns",
      "iconSize": 128,
      "contents": [
        {
          "x": 380,
          "y": 180,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 130,
          "y": 180,
          "type": "file"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "files": [
      "dist/renderer/**/*",
      "src/main/**/*",
      "package.json"
    ],
    "directories": {
      "output": "out"
    },
    "asar": true
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.6.0",
    "@electron-forge/maker-dmg": "^7.6.0",
    "@electron-forge/maker-zip": "^7.6.0",
    "@electron-forge/plugin-vite": "^7.6.0",
    "@electron/notarize": "^2.5.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.2.1",
    "electron": "^33.0.0",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "vite": "^5.4.0",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.79.0",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.3.1",
    "electron-store": "^11.0.2",
    "openai": "^6.31.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  }
}
