# Verby development environment variables
# Copy to .env and fill in your values. NEVER commit .env.

# AI providers (user's own keys — only used in dev, not shipped)
OPENAI_API_KEY=sk-proj-your-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here
DEFAULT_PROVIDER=openai

# Stripe (secret key — NEVER ships in builds, dev/server only)
STRIPE_SECRET_KEY=sk_test_your-key-here
STRIPE_PRODUCT_ID=prod_your-product-id
STRIPE_PAYMENT_LINK=https://buy.stripe.com/your-link

# Apple code signing (local builds only)
APPLE_ID=your@email.com
APPLE_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
APPLE_TEAM_ID=XXXXXXXXXX
APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx

# GitHub (auto-updater — fine-grained read-only PAT)
GH_TOKEN=ghp_your-token
GH_UPDATE_TOKEN=github_pat_your-fine-grained-token

# Supabase (anon key is public, service role is server-only)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
